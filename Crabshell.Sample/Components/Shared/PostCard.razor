<div style="background:var(--rz-base-background-color);border:1px solid var(--rz-border-color);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;height:100%">

    @if (!string.IsNullOrWhiteSpace(Post.CoverImage))
    {
        <img src="@Post.CoverImage" alt="@Post.Title"
             style="width:100%;height:160px;object-fit:cover" />
    }
    else
    {
        <div style="background:linear-gradient(135deg,var(--rz-primary-lighter),var(--rz-primary-light));height:120px;display:flex;align-items:center;justify-content:center">
            <RadzenIcon Icon="article" Style="font-size:48px;color:var(--rz-primary);opacity:0.35" />
        </div>
    }

    <div style="padding:16px;flex:1;display:flex;flex-direction:column;gap:8px">

        <!-- CATEGORY + DATE -->
        <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" AlignItems="AlignItems.Center">
            @if (!string.IsNullOrWhiteSpace(CategoryName))
            {
                <RadzenBadge BadgeStyle="BadgeStyle.Primary" Text="@CategoryName" />
            }
            @if (Post.PublishedAt.HasValue)
            {
                <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color)">
                    @Post.PublishedAt.Value.ToString("MMM d, yyyy")
                </RadzenText>
            }
        </RadzenStack>

        <!-- TITLE -->
        <RadzenText TextStyle="TextStyle.H6" Style="font-weight:700;margin:0;line-height:1.3">
            @Post.Title
        </RadzenText>

        <!-- EXCERPT -->
        @if (!string.IsNullOrWhiteSpace(Post.Excerpt))
        {
            <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-text-secondary-color);line-height:1.5">
                @(Post.Excerpt.Length > 120 ? Post.Excerpt[..120] + "…" : Post.Excerpt)
            </RadzenText>
        }

        <!-- AUTHOR + READ TIME -->
        <RadzenStack Orientation="Orientation.Horizontal" Gap="10px" AlignItems="AlignItems.Center" Style="margin-top:auto;padding-top:8px">
            @if (!string.IsNullOrWhiteSpace(AuthorName))
            {
                <div style="display:flex;align-items:center;gap:6px">
                    <div style="width:24px;height:24px;border-radius:50%;background:var(--rz-primary-lighter);display:flex;align-items:center;justify-content:center">
                        <RadzenIcon Icon="person" Style="font-size:14px;color:var(--rz-primary)" />
                    </div>
                    <RadzenText TextStyle="TextStyle.Caption" Style="font-weight:600">@AuthorName</RadzenText>
                </div>
            }
            @if (Post.ReadTimeMinutes.HasValue)
            {
                <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color);margin-left:auto">
                    @Post.ReadTimeMinutes min read
                </RadzenText>
            }
        </RadzenStack>

        <RadzenButton Text="Read Post" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Outlined"
                      Size="ButtonSize.Small" Style="width:100%;margin-top:4px"
                      NavigateUrl="@($"/blog/{Post.Slug}")" />
    </div>
</div>

@code {
    [Parameter] public required BlogPost Post { get; set; }
    [Parameter] public string? CategoryName { get; set; }
    [Parameter] public string? AuthorName { get; set; }
}
