@page "/listings/{Id:guid}"
@inject ICollectionService CollectionService
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>@(listing?.Address ?? "Listing")</PageTitle>

@if (isLoading)
{
    <RadzenStack AlignItems="AlignItems.Center" Style="padding:80px">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    </RadzenStack>
}
else if (listing is null)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false">Listing not found.</RadzenAlert>
}
else
{
    <RadzenButton Text="← Back to Listings" Variant="Variant.Text" ButtonStyle="ButtonStyle.Secondary"
                  Style="margin-bottom:20px" NavigateUrl="/listings" />

    <!-- HEADER -->
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween"
                 AlignItems="AlignItems.Start" Style="margin-bottom:28px">
        <div>
            <RadzenText TextStyle="TextStyle.H4" Style="font-weight:800;margin:0">@listing.Address</RadzenText>
            @if (!string.IsNullOrWhiteSpace(listing.Headline))
            {
                <RadzenText TextStyle="TextStyle.H6" Style="color:var(--rz-text-secondary-color);margin:4px 0 0">
                    @listing.Headline
                </RadzenText>
            }
        </div>
        <RadzenStack AlignItems="AlignItems.End" Gap="6px">
            <RadzenText TextStyle="TextStyle.H4" Style="font-weight:800;color:var(--rz-primary);margin:0">
                @listing.Price.ToString("C0")
            </RadzenText>
            <RadzenBadge BadgeStyle="@StatusStyle" Text="@listing.Status.ToString()" />
        </RadzenStack>
    </RadzenStack>

    <RadzenStack Orientation="Orientation.Horizontal" Gap="24px" AlignItems="AlignItems.Start">

        <!-- MAIN -->
        <div style="flex:1;min-width:0">
            <!-- KEY FACTS -->
            <RadzenCard Style="margin-bottom:20px">
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:16px">
                    @Fact("Bedrooms",     listing.Bedrooms.ToString())
                    @Fact("Bathrooms",    listing.Bathrooms.ToString("G"))
                    @if (listing.SquareFeet.HasValue)   { @Fact("Sq Ft",       listing.SquareFeet.Value.ToString("N0")) }
                    @if (listing.YearBuilt.HasValue)    { @Fact("Year Built",  listing.YearBuilt.Value.ToString()) }
                    @if (listing.Floors.HasValue)       { @Fact("Floors",      listing.Floors.Value.ToString()) }
                    @if (listing.ParkingSpaces.HasValue){ @Fact("Parking",     listing.ParkingSpaces.Value.ToString()) }
                    @if (listing.LotSizeAcres.HasValue) { @Fact("Lot Size",    $"{listing.LotSizeAcres.Value:G} ac") }
                    @if (listing.Condition.HasValue)    { @Fact("Condition",   listing.Condition.Value.ToString()) }
                </div>
            </RadzenCard>

            <!-- DESCRIPTION -->
            @if (!string.IsNullOrWhiteSpace(listing.Description))
            {
                <RadzenCard Style="margin-bottom:20px">
                    <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight:700;margin-bottom:12px">About this property</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body1" Style="white-space:pre-line">@listing.Description</RadzenText>
                </RadzenCard>
            }

            <!-- FEATURES -->
            @{
                var features = new List<string>();
                if (listing.HasPool)        features.Add("Pool");
                if (listing.HasGarage)      features.Add("Garage");
                if (listing.PetFriendly)    features.Add("Pet Friendly");
                if (listing.NewConstruction)features.Add("New Construction");
                if (listing.Furnished)      features.Add("Furnished");
            }
            @if (features.Count > 0)
            {
                <RadzenCard>
                    <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight:700;margin-bottom:12px">Features</RadzenText>
                    <RadzenStack Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap" Gap="8px">
                        @foreach (var f in features)
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="@f" />
                        }
                    </RadzenStack>
                </RadzenCard>
            }
        </div>

        <!-- SIDEBAR -->
        <RadzenStack Style="width:280px;flex-shrink:0" Gap="16px">

            <!-- PRICING -->
            <RadzenCard Style="padding:0;overflow:hidden">
                <div style="padding:12px 16px;border-bottom:1px solid var(--rz-border-color)">
                    <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:var(--rz-text-secondary-color)">Pricing</RadzenText>
                </div>
                <div style="padding:14px 16px">
                    <RadzenStack Gap="10px">
                        @SidebarItem("List Price", listing.Price.ToString("C0"))
                        @if (listing.HoaFee.HasValue)    { @SidebarItem("HOA Fee",       $"{listing.HoaFee.Value:C0} /mo") }
                        @if (listing.AnnualTaxes.HasValue){ @SidebarItem("Annual Taxes", listing.AnnualTaxes.Value.ToString("C0")) }
                    </RadzenStack>
                </div>
            </RadzenCard>

            <!-- DATES -->
            @if (listing.ListedAt.HasValue || listing.OpenHouseAt.HasValue || listing.OfferDeadline.HasValue)
            {
                <RadzenCard Style="padding:0;overflow:hidden">
                    <div style="padding:12px 16px;border-bottom:1px solid var(--rz-border-color)">
                        <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:var(--rz-text-secondary-color)">Dates</RadzenText>
                    </div>
                    <div style="padding:14px 16px">
                        <RadzenStack Gap="10px">
                            @if (listing.ListedAt.HasValue)     { @SidebarItem("Listed On",      listing.ListedAt.Value.ToString("MMM d, yyyy")) }
                            @if (listing.OpenHouseAt.HasValue)  { @SidebarItem("Open House",     listing.OpenHouseAt.Value.ToString("MMM d, yyyy · h:mm tt")) }
                            @if (listing.OfferDeadline.HasValue){ @SidebarItem("Offer Deadline", listing.OfferDeadline.Value.ToString("MMM d, yyyy · h:mm tt")) }
                        </RadzenStack>
                    </div>
                </RadzenCard>
            }

            <!-- AGENT -->
            @if (agent is not null)
            {
                <RadzenCard Style="padding:0;overflow:hidden">
                    <div style="padding:12px 16px;border-bottom:1px solid var(--rz-border-color)">
                        <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:var(--rz-text-secondary-color)">Listing Agent</RadzenText>
                    </div>
                    <div style="padding:14px 16px">
                        <RadzenStack Gap="8px">
                            <RadzenText TextStyle="TextStyle.Subtitle1" Style="font-weight:700;margin:0">@agent.Name</RadzenText>
                            @if (!string.IsNullOrWhiteSpace(agent.Phone))
                            {
                                <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-text-secondary-color)">@agent.Phone</RadzenText>
                            }
                            @if (!string.IsNullOrWhiteSpace(agent.Email))
                            {
                                <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-primary)">@agent.Email</RadzenText>
                            }
                        </RadzenStack>
                    </div>
                </RadzenCard>
            }

            <!-- NEIGHBORHOOD -->
            @if (neighborhood is not null)
            {
                <RadzenCard Style="padding:0;overflow:hidden">
                    <div style="padding:12px 16px;border-bottom:1px solid var(--rz-border-color)">
                        <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:var(--rz-text-secondary-color)">Neighborhood</RadzenText>
                    </div>
                    <div style="padding:14px 16px">
                        <RadzenStack Gap="8px">
                            <RadzenText TextStyle="TextStyle.Subtitle1" Style="font-weight:700;margin:0">@neighborhood.Name</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-text-secondary-color)">
                                @neighborhood.City, @neighborhood.State
                            </RadzenText>
                            @if (neighborhood.MedianPrice.HasValue)
                            {
                                @SidebarItem("Median Price", neighborhood.MedianPrice.Value.ToString("C0"))
                            }
                            @if (neighborhood.WalkabilityScore.HasValue)
                            {
                                @SidebarItem("Walkability", $"{neighborhood.WalkabilityScore.Value} / 100")
                            }
                        </RadzenStack>
                    </div>
                </RadzenCard>
            }

        </RadzenStack>
    </RadzenStack>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Listing?      listing;
    private Agent?        agent;
    private Neighborhood? neighborhood;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        listing = null; agent = null; neighborhood = null;

        var result = await CollectionService.GetByIdAsync("listings", Id);
        if (result is not Result<CrabshellDocument?>.Ok { Value: var rawListing })
        {
            isLoading = false;
            return;
        }
        listing = rawListing as Listing;
        if (listing is null) { isLoading = false; return; }

        if (listing.AgentId != Guid.Empty)
        {
            var ar = await CollectionService.GetByIdAsync("agents", listing.AgentId);
            if (ar is Result<CrabshellDocument?>.Ok { Value: var rawAgent })
                agent = rawAgent as Agent;
        }

        if (listing.NeighborhoodId != Guid.Empty)
        {
            var nr = await CollectionService.GetByIdAsync("neighborhoods", listing.NeighborhoodId);
            if (nr is Result<CrabshellDocument?>.Ok { Value: var rawNb })
                neighborhood = rawNb as Neighborhood;
        }

        isLoading = false;
    }

    private BadgeStyle StatusStyle => listing?.Status switch
    {
        ListingStatus.Active     => BadgeStyle.Success,
        ListingStatus.Pending    => BadgeStyle.Warning,
        ListingStatus.Sold       => BadgeStyle.Danger,
        ListingStatus.ComingSoon => BadgeStyle.Info,
        _                        => BadgeStyle.Light
    };

    private RenderFragment Fact(string label, string value) => __builder =>
    {
        <div style="text-align:center;padding:12px;background:var(--rz-base-100);border-radius:8px">
            <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color);display:block">@label</RadzenText>
            <RadzenText TextStyle="TextStyle.Body1" Style="font-weight:700">@value</RadzenText>
        </div>;
    };

    private RenderFragment SidebarItem(string label, string value) => __builder =>
    {
        <div>
            <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color);display:block;margin-bottom:2px">@label</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="font-weight:600">@value</RadzenText>
        </div>;
    };
}
