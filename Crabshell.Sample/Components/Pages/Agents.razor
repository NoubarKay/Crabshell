@page "/agents"
@inject ICollectionService CollectionService
@rendermode InteractiveServer

<PageTitle>Agents</PageTitle>

<RadzenText TextStyle="TextStyle.H4" Style="font-weight:700;margin-bottom:24px">Our Agents</RadzenText>

@if (isLoading)
{
    <RadzenStack AlignItems="AlignItems.Center" Style="padding:80px">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    </RadzenStack>
}
else if (agents.Count == 0)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" AllowClose="false">
        No agents yet. Add some from the <a href="/admin">admin panel</a>.
    </RadzenAlert>
}
else
{
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:20px">
        @foreach (var agent in agents)
        {
            var agencyName = agencyNames.GetValueOrDefault(agent.AgencyId);
            <RadzenCard Style="padding:0;overflow:hidden">
                <div style="background:linear-gradient(135deg,var(--rz-primary-lighter),var(--rz-primary-light));height:72px;display:flex;align-items:center;justify-content:center">
                    <RadzenIcon Icon="person" Style="font-size:40px;color:var(--rz-primary);opacity:0.35" />
                </div>
                <div style="padding:16px">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween"
                                 AlignItems="AlignItems.Start" Style="margin-bottom:6px">
                        <RadzenText TextStyle="TextStyle.Subtitle1" Style="font-weight:700;margin:0">@agent.Name</RadzenText>
                        <RadzenBadge BadgeStyle="@(agent.IsActive ? BadgeStyle.Success : BadgeStyle.Light)"
                                     Text="@(agent.IsActive ? "Active" : "Inactive")" />
                    </RadzenStack>

                    @if (agencyName is not null)
                    {
                        <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-primary);margin-bottom:10px">@agencyName</RadzenText>
                    }

                    <RadzenStack Gap="6px">
                        @if (!string.IsNullOrWhiteSpace(agent.Email))
                        {
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="6px" AlignItems="AlignItems.Center">
                                <RadzenIcon Icon="email" Style="font-size:14px;color:var(--rz-text-secondary-color)" />
                                <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-text-secondary-color)">@agent.Email</RadzenText>
                            </RadzenStack>
                        }
                        @if (!string.IsNullOrWhiteSpace(agent.Phone))
                        {
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="6px" AlignItems="AlignItems.Center">
                                <RadzenIcon Icon="phone" Style="font-size:14px;color:var(--rz-text-secondary-color)" />
                                <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-text-secondary-color)">@agent.Phone</RadzenText>
                            </RadzenStack>
                        }
                        @if (!string.IsNullOrWhiteSpace(agent.LicenseNumber))
                        {
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="6px" AlignItems="AlignItems.Center">
                                <RadzenIcon Icon="badge" Style="font-size:14px;color:var(--rz-text-secondary-color)" />
                                <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-text-secondary-color)">@agent.LicenseNumber</RadzenText>
                            </RadzenStack>
                        }
                    </RadzenStack>

                    @if (agent.YearsExperience.HasValue || agent.Rating.HasValue)
                    {
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="16px" Style="margin-top:12px;padding-top:12px;border-top:1px solid var(--rz-border-color)">
                            @if (agent.YearsExperience.HasValue)
                            {
                                <div>
                                    <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color);display:block">Experience</RadzenText>
                                    <RadzenText TextStyle="TextStyle.Body2" Style="font-weight:700">@agent.YearsExperience yrs</RadzenText>
                                </div>
                            }
                            @if (agent.Rating.HasValue)
                            {
                                <div>
                                    <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color);display:block">Rating</RadzenText>
                                    <RadzenText TextStyle="TextStyle.Body2" Style="font-weight:700">⭐ @agent.Rating.Value.ToString("G")</RadzenText>
                                </div>
                            }
                        </RadzenStack>
                    }
                </div>
            </RadzenCard>
        }
    </div>
}

@code {
    private List<Agent> agents = [];
    private Dictionary<Guid, string?> agencyNames = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var result = await CollectionService.GetPageAsync("agents", new CollectionQuery(Take: 1000, OrderBy: nameof(Agent.Name)));
        if (result is Result<PagedResult>.Ok { Value: var page })
            agents = page.Items.OfType<Agent>().ToList();

        var agencyResult = await CollectionService.GetPageAsync("agencies", new CollectionQuery(Take: 1000));
        if (agencyResult is Result<PagedResult>.Ok { Value: var ap })
        {
            foreach (var agency in ap.Items.OfType<Agency>())
                agencyNames[agency.Id] = agency.Name;
        }

        isLoading = false;
    }
}
