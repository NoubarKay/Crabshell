@page "/"
@inject ICollectionService CollectionService
@rendermode InteractiveServer

<PageTitle>@(siteSettings?.SiteName ?? "The Blog")</PageTitle>

@if (isLoading)
{
    <RadzenStack AlignItems="AlignItems.Center" Style="padding:80px">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    </RadzenStack>
}
else
{
    <!-- HERO -->
    <div style="background:linear-gradient(135deg,#1a1a2e 0%,#16213e 55%,#0f3460 100%);border-radius:16px;padding:72px 48px;margin-bottom:40px;text-align:center">
        <RadzenText TextStyle="TextStyle.H2" Style="color:white;font-weight:800;margin-bottom:12px">
            @(siteSettings?.SiteName ?? "The Blog")
        </RadzenText>
        @if (!string.IsNullOrWhiteSpace(siteSettings?.Tagline))
        {
            <RadzenText TextStyle="TextStyle.H6" Style="color:rgba(255,255,255,0.65);margin-bottom:32px;display:block">
                @siteSettings.Tagline
            </RadzenText>
        }
        <RadzenButton Text="Browse All Posts" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Large"
                      NavigateUrl="/blog" Style="margin-top:8px" />
    </div>

    <!-- STATS -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:48px">
        <div style="background:var(--rz-base-background-color);border:1px solid var(--rz-border-color);border-radius:12px;padding:28px;text-align:center">
            <RadzenText TextStyle="TextStyle.H3" Style="font-weight:800;color:var(--rz-primary);margin:0">@publishedCount</RadzenText>
            <RadzenText TextStyle="TextStyle.Body1" Style="color:var(--rz-text-secondary-color);margin:0">Published Posts</RadzenText>
        </div>
        <div style="background:var(--rz-base-background-color);border:1px solid var(--rz-border-color);border-radius:12px;padding:28px;text-align:center">
            <RadzenText TextStyle="TextStyle.H3" Style="font-weight:800;color:var(--rz-primary);margin:0">@authorCount</RadzenText>
            <RadzenText TextStyle="TextStyle.Body1" Style="color:var(--rz-text-secondary-color);margin:0">Authors</RadzenText>
        </div>
        <div style="background:var(--rz-base-background-color);border:1px solid var(--rz-border-color);border-radius:12px;padding:28px;text-align:center">
            <RadzenText TextStyle="TextStyle.H3" Style="font-weight:800;color:var(--rz-primary);margin:0">@categoryCount</RadzenText>
            <RadzenText TextStyle="TextStyle.Body1" Style="color:var(--rz-text-secondary-color);margin:0">Categories</RadzenText>
        </div>
    </div>

    <!-- FEATURED POSTS -->
    @if (featuredPosts.Count > 0)
    {
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween"
                     AlignItems="AlignItems.Center" Style="margin-bottom:20px">
            <RadzenText TextStyle="TextStyle.H5" Style="font-weight:700;margin:0">Featured Posts</RadzenText>
            <RadzenButton Text="View All" Variant="Variant.Text" ButtonStyle="ButtonStyle.Primary"
                          NavigateUrl="/blog" />
        </RadzenStack>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px;margin-bottom:48px">
            @foreach (var post in featuredPosts)
            {
                <PostCard Post="post" CategoryName="@categoryNames.GetValueOrDefault(post.CategoryId)"
                          AuthorName="@authorNames.GetValueOrDefault(post.AuthorId)" />
            }
        </div>
    }

    <!-- LATEST POSTS -->
    @if (latestPosts.Count > 0)
    {
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween"
                     AlignItems="AlignItems.Center" Style="margin-bottom:20px">
            <RadzenText TextStyle="TextStyle.H5" Style="font-weight:700;margin:0">Latest Posts</RadzenText>
            <RadzenButton Text="View All" Variant="Variant.Text" ButtonStyle="ButtonStyle.Primary"
                          NavigateUrl="/blog" />
        </RadzenStack>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px">
            @foreach (var post in latestPosts)
            {
                <PostCard Post="post" CategoryName="@categoryNames.GetValueOrDefault(post.CategoryId)"
                          AuthorName="@authorNames.GetValueOrDefault(post.AuthorId)" />
            }
        </div>
    }

    @if (featuredPosts.Count == 0 && latestPosts.Count == 0)
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" AllowClose="false">
            No published posts yet. Add some from the <a href="/admin">admin panel</a>.
        </RadzenAlert>
    }
}

@code {
    private SiteSettings? siteSettings;
    private List<BlogPost> featuredPosts = [];
    private List<BlogPost> latestPosts = [];
    private Dictionary<Guid, string?> authorNames = new();
    private Dictionary<Guid, string?> categoryNames = new();
    private int publishedCount, authorCount, categoryCount;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var settingsResult = await CollectionService.GetSingleAsync("site_settings");
        if (settingsResult is Result<CrabshellDocument>.Ok { Value: var rawSettings })
            siteSettings = rawSettings as SiteSettings;

        var authorsResult = await CollectionService.GetPageAsync("authors", new CollectionQuery(Take: 1000));
        if (authorsResult is Result<PagedResult>.Ok { Value: var ap })
        {
            authorCount = ap.TotalCount;
            foreach (var a in ap.Items.OfType<Author>())
                authorNames[a.Id] = a.Name;
        }

        var categoriesResult = await CollectionService.GetPageAsync("categories", new CollectionQuery(Take: 1000));
        if (categoriesResult is Result<PagedResult>.Ok { Value: var cp })
        {
            categoryCount = cp.TotalCount;
            foreach (var c in cp.Items.OfType<Category>())
                categoryNames[c.Id] = c.Name;
        }

        var postsResult = await CollectionService.GetPageAsync("blog_posts",
            new CollectionQuery(Take: 1000, OrderBy: nameof(BlogPost.PublishedAt), Descending: true,
                Filters: [new FieldFilter(nameof(BlogPost.Status), FieldFilterOperator.Equals, PostStatus.Published.ToString())]));
        if (postsResult is Result<PagedResult>.Ok { Value: var pp })
        {
            var all = pp.Items.OfType<BlogPost>().ToList();
            publishedCount = all.Count;
            featuredPosts  = all.Where(p => p.IsFeatured).Take(3).ToList();
            latestPosts    = all.Except(featuredPosts).Take(6).ToList();
        }

        isLoading = false;
    }
}
