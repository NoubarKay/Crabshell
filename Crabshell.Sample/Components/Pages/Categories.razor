@page "/categories"
@inject ICollectionService CollectionService
@rendermode InteractiveServer

<PageTitle>Categories</PageTitle>

<RadzenText TextStyle="TextStyle.H4" Style="font-weight:700;margin-bottom:24px">Categories</RadzenText>

@if (isLoading)
{
    <RadzenStack AlignItems="AlignItems.Center" Style="padding:80px">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    </RadzenStack>
}
else if (categories.Count == 0)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" AllowClose="false">
        No categories yet. Add some from the <a href="/admin">admin panel</a>.
    </RadzenAlert>
}
else
{
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:20px">
        @foreach (var cat in categories)
        {
            var color  = string.IsNullOrWhiteSpace(cat.Color) ? "#6366f1" : cat.Color;
            var count  = postCounts.GetValueOrDefault(cat.Id, 0);
            <RadzenCard Style="padding:0;overflow:hidden">
                <div style="background:@color;height:72px;display:flex;align-items:center;padding:0 20px">
                    <RadzenText TextStyle="TextStyle.H6" Style="color:white;font-weight:700;margin:0">@cat.Name</RadzenText>
                </div>
                <div style="padding:16px">
                    @if (!string.IsNullOrWhiteSpace(cat.Description))
                    {
                        <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-text-secondary-color);margin-bottom:12px;line-height:1.5">
                            @(cat.Description.Length > 120 ? cat.Description[..120] + "…" : cat.Description)
                        </RadzenText>
                    }
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween"
                                 AlignItems="AlignItems.Center">
                        <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color)">
                            @count post@(count == 1 ? "" : "s")
                        </RadzenText>
                        <RadzenButton Text="Browse" Variant="Variant.Outlined" ButtonStyle="ButtonStyle.Secondary"
                                      Size="ButtonSize.Small"
                                      NavigateUrl="@($"/blog?category={cat.Slug}")" />
                    </RadzenStack>
                </div>
            </RadzenCard>
        }
    </div>
}

@code {
    private List<Category> categories = [];
    private Dictionary<Guid, int> postCounts = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var catTask   = CollectionService.GetPageAsync("categories",
            new CollectionQuery(Take: 1000, OrderBy: nameof(Category.Name)));
        var postsTask = CollectionService.GetPageAsync("blog_posts",
            new CollectionQuery(Take: 1000,
                Filters: [new FieldFilter(nameof(BlogPost.Status), FieldFilterOperator.Equals, PostStatus.Published.ToString())]));

        await Task.WhenAll(catTask, postsTask);

        if (catTask.Result is Result<PagedResult>.Ok { Value: var cp })
            categories = cp.Items.OfType<Category>().ToList();

        if (postsTask.Result is Result<PagedResult>.Ok { Value: var pp })
            foreach (var post in pp.Items.OfType<BlogPost>())
                postCounts[post.CategoryId] = postCounts.GetValueOrDefault(post.CategoryId) + 1;

        isLoading = false;
    }
}
