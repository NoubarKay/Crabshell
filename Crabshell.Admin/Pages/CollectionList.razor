@page "/admin/collections/{Slug}"
@layout Crabshell.Admin.Layout.AdminLayout
@inject CollectionRegistry Registry
@inject ICollectionService CollectionService
@inject NavigationManager Nav
@inject IServiceProvider ServiceProvider
@rendermode InteractiveServer

<!-- HEADER -->
<div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:28px">
    <div>
        <RadzenText TextStyle="TextStyle.Caption"
                    Style="color:var(--rz-text-secondary-color);display:block;margin-bottom:4px;font-weight:500">
            Collections
        </RadzenText>
        <RadzenText TextStyle="TextStyle.H5" Style="font-weight:700;margin:0">
            @collection?.Label
        </RadzenText>
    </div>
    <div style="display: flex;flex-direction: row; align-items: center; justify-content: center; gap: 1rem;">
        <RadzenButton Text="@($"New {collection?.Label}")"
                      ButtonStyle="ButtonStyle.Primary"
                      Click="@(() => Nav.NavigateTo($"/admin/collections/{Slug}/new"))" />
    
        @if (collection?.CustomBulkOptions.Any() == true && selectedDocuments.Any())
        {
            <RadzenSplitButton Text="@($"Actions ({selectedDocuments.Count})")"
                               ButtonStyle="ButtonStyle.Secondary"
                               Click="@OnBulkAction">
                <ChildContent>
                    @foreach (var action in collection.CustomBulkOptions)
                    {
                        <RadzenSplitButtonItem Text="@action.Label" Value="@action.Value" />
                    }
                </ChildContent>
            </RadzenSplitButton>
        }
    </div>
        
</div>

@if (collection is not null)
{
    <RadzenCard Style="padding:0;overflow:hidden">
        <RadzenDataGrid Data="@documents"
                        TItem="CrabshellDocument"
                        AllowSorting="true"
                        LoadData="LoadData"
                        IsLoading=@isLoading
                        AllowFiltering="true"
                        AllowPaging="true"
                        PageSize="20"
                        FilterMode="FilterMode.Advanced"
                        Count="@count"
                        ShowPagingSummary="true"
                        PageSizeOptions="pageSizeOptions"
                        SelectionMode="DataGridSelectionMode.Multiple"
                        @bind-Value="selectedDocuments"
                        AllowRowSelectOnRowClick="false"
                        Style="border:none">
                <Columns>
                    <RadzenDataGridColumn TItem="CrabshellDocument" Width="48px" Sortable="false" Filterable="false">
                        <HeaderTemplate>
                            <RadzenCheckBox TValue="bool"
                                            Value="@(documents.Any() && documents.All(d => selectedDocuments.Contains(d)))"
                                            Change="@(v => selectedDocuments = v ? documents.ToList() : [])" />
                        </HeaderTemplate>
                        <Template Context="doc">
                            <RadzenCheckBox TValue="bool"
                                            Value="@(selectedDocuments.Contains(doc))"
                                            Change="@(_ => ToggleSelection(doc))" />
                        </Template>
                    </RadzenDataGridColumn>
                    @foreach (var field in collection.Fields
                                  .Where(f => f.GridVisible)
                                  .OrderBy(f => f.GridOrder))
                    {
                        var f = field;
                        <RadzenDataGridColumn TItem="CrabshellDocument"
                            Type="@f.ClrType"
                            Title="@f.Label"
                            Width="@(f.GridWidth > 0 ? $"{f.GridWidth}px" : "")"
                            Sortable="@f.GridSortable"
                            Filterable="@f.GridFilterable"
                            Property="@f.PropertyName">
                            <Template Context="doc">
                                @GetDisplayValue(doc, f)
                            </Template>
                        </RadzenDataGridColumn>
                    }
                    <RadzenDataGridColumn TItem="CrabshellDocument" Filterable="false" Sortable="false" TextAlign="TextAlign.Center" Frozen="true" FrozenPosition="FrozenColumnPosition.Right" Width="120px">
                        <Template Context="doc">
                            <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Medium" class="rz-my-1 rz-ms-1" @onclick:stopPropagation="true"
                                          Click="@(() => Nav.NavigateTo($"/admin/collections/{Slug}/{doc.Id}"))" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Size="ButtonSize.Medium" Shade="Shade.Lighter" class="rz-my-1 rz-ms-1" @onclick:stopPropagation="true"
                                          Click="@(() => Delete(doc))" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
    </RadzenCard>
}

@code {
    [Parameter] public string Slug { get; set; } = default!;
    private List<CrabshellDocument> documents = [];
    private IList<CrabshellDocument> selectedDocuments = [];
    private CollectionMeta? collection;
    private Dictionary<string, List<CrabshellDocument>> relatedDocuments = new();
    int count;
    bool isLoading;
    IEnumerable<int> pageSizeOptions = new int[] { 10, 20, 30 };

    protected override async Task OnParametersSetAsync()
    {
        await LoadData(new LoadDataArgs());
    }

    private async Task LoadData(LoadDataArgs args)
    {
        isLoading = true;
        collection = Registry.Get(Slug);
        if (collection is null)
        {
            isLoading = false;
            return;
        }

        IQueryable<CrabshellDocument> query = await CollectionService.GetAllAsync(Slug);

        relatedDocuments = new();
        foreach (var field in collection.Fields.Where(f => f.FieldType == FieldType.Relationship && f.GridVisible))
        {
            if (field.RelationshipSettings is null) continue;
            relatedDocuments[field.PropertyName] = (await CollectionService.GetAllAsync(field.RelationshipSettings.Slug)).ToList();
        }

        foreach (var f in args.Filters ?? Enumerable.Empty<FilterDescriptor>())
        {
            if(f.FilterValue is null) continue;

            var fieldMeta = collection.Fields.FirstOrDefault(x => x.PropertyName == f.Property);
            
            if(fieldMeta is null) continue;

            var param = Expression.Parameter(typeof(CrabshellDocument), "doc");
            var prop = Expression.Property(Expression.Convert(param, collection.ClrType), f.Property);

            var underlyingType = Nullable.GetUnderlyingType(fieldMeta.ClrType) ?? fieldMeta.ClrType;
            var convertedValue = Convert.ChangeType(f.FilterValue, underlyingType);
            var constant = Expression.Constant(convertedValue, fieldMeta.ClrType);
            
            Expression? body = f.FilterOperator switch
            {
                FilterOperator.Contains => Expression.Call(prop, nameof(string.Contains),    null, constant),
                FilterOperator.DoesNotContain => Expression.Call(prop, nameof(string.Contains),    null, constant),
                FilterOperator.StartsWith => Expression.Call(prop, nameof(string.StartsWith),  null, constant),
                FilterOperator.EndsWith => Expression.Call(prop, nameof(string.EndsWith),    null, constant),
                FilterOperator.Equals => Expression.Equal(prop, constant),
                FilterOperator.NotEquals => Expression.NotEqual(prop, constant),
                FilterOperator.GreaterThan => Expression.GreaterThan(prop, constant),
                FilterOperator.GreaterThanOrEquals => Expression.GreaterThanOrEqual(prop, constant),
                FilterOperator.LessThan => Expression.LessThan(prop, constant),
                FilterOperator.LessThanOrEquals => Expression.LessThanOrEqual(prop, constant),
                _ => null
            };
            
            if (body is null) continue;
            query = query.Where(Expression.Lambda<Func<CrabshellDocument, bool>>(body, param));

        }

        if (!string.IsNullOrEmpty(args.OrderBy))
        {
            var parts = args.OrderBy.Split(' ');
            var propName = parts[0];
            var desc = parts.Length > 1 && parts[1].Equals("desc", StringComparison.OrdinalIgnoreCase);
            var sortField = collection.Fields.FirstOrDefault(f => f.PropertyName == propName);
            if (sortField is not null)
            {
                var param = Expression.Parameter(typeof(CrabshellDocument), "doc");
                var keySelector = Expression.Lambda(
                    Expression.Property(Expression.Convert(param, collection.ClrType), propName),
                    param);
                var orderMethod = desc ? "OrderByDescending" : "OrderBy";
                var method = typeof(Queryable)
                    .GetMethods()
                    .First(m => m.Name == orderMethod && m.GetParameters().Length == 2)
                    .MakeGenericMethod(typeof(CrabshellDocument), sortField.ClrType);
                query = (IQueryable<CrabshellDocument>)method.Invoke(null, [query, keySelector])!;
            }
        }

        IEnumerable<CrabshellDocument> result = query;

        count = result.Count();


        if (args.Skip != null && args.Top != null)
            result = result.Skip(args.Skip.Value).Take(args.Top.Value);

        
        documents = result.ToList();

        isLoading = false;
    }

    private async Task OnBulkAction(RadzenSplitButtonItem item)
    {
        var action = collection?.CustomBulkOptions.FirstOrDefault(a => a.Value == item.Value);
        if (action is null) return;

        var ctx = new BulkActionContext(
            Slug,
            selectedDocuments.Select(d => d.Id).ToList(),
            CollectionService,
            ServiceProvider
        );
        await action.ExecuteAsync(ctx);
        selectedDocuments = [];
        await LoadData(new LoadDataArgs());
    }

    private void ToggleSelection(CrabshellDocument doc)
    {
        var list = selectedDocuments.ToList();
        if (list.Contains(doc)) list.Remove(doc);
        else list.Add(doc);
        selectedDocuments = list;
    }

    private async Task Delete(CrabshellDocument doc)
    {
        await CollectionService.DeleteAsync(Slug, doc.Id);
        await LoadData(new LoadDataArgs());
    }

    private string GetDisplayValue(CrabshellDocument doc, FieldMeta field)
    {
        if (field.FieldType != FieldType.Relationship)
            return field.Getter(doc)?.ToString() ?? "";

        if (field.RelationshipSettings is null)
            return field.Getter(doc)?.ToString() ?? "";

        var rawValue = field.Getter(doc)?.ToString();
        if (rawValue is null) return "";

        if (!relatedDocuments.TryGetValue(field.PropertyName, out var docs))
            return rawValue;

        var relatedDoc = docs.FirstOrDefault(d => d.Id.ToString() == rawValue);
        if (relatedDoc is null) return rawValue;

        var relatedMeta = Registry.Get(field.RelationshipSettings.Slug);
        var firstTextField = relatedMeta?.Fields.FirstOrDefault(f => f.FieldType == FieldType.Text);
        return firstTextField?.Getter(relatedDoc)?.ToString() ?? rawValue;
    }
    
}
